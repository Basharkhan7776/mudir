# Firebase Configuration
# Copy this file to .env and fill in your values

# Environment (development or production)
ENVIRONMENT=development

# Firebase Web API Key
FIREBASE_API_KEY=your-firebase-api-key

# Firebase Auth Domain (e.g., your-app.firebaseapp.com)
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com

# Firebase Project ID (from Firebase Console)
FIREBASE_PROJECT_ID=your-project-id

# Firebase Storage Bucket (e.g., your-app.appspot.com)
FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# Firebase Messaging Sender ID (from Firebase Console > Project Settings)
FIREBASE_MESSAGING_SENDER_ID=123456789

# Firebase App ID (from Firebase Console > Project Settings)
FIREBASE_APP_ID=1:123456789:web:abcdef

# Firebase Database URL (Realtime Database)
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com

# Google Sign-In Configuration
# Get these from Google Cloud Console > APIs & Services > Credentials
GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com

# How to set up Firebase:
# 1. Go to https://console.firebase.google.com/
# 2. Create a new project
# 3. Enable Authentication > Google Sign-In provider
# 4. Enable Realtime Database
# 5. Set Realtime Database rules (for testing):
#    {
#      "rules": {
#        ".read": "auth != null",
#        ".write": "auth != null"
#      }
#    }
# 6. Copy the configuration values from Project Settings
